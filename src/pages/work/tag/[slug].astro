---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import WorkGrid from '../../../components/WorkGrid.astro';
import type { CollectionEntry } from 'astro:content';
export const prerender = true;

export async function getStaticPaths() {
  const works = await getCollection('work');

  // Build category map for nav
  const categoryMap = new Map<string, { name: string; slug: string; count: number }>();
  for (const entry of works) {
    for (const cat of entry.data.categories ?? []) {
      const existing = categoryMap.get(cat.slug);
      categoryMap.set(cat.slug, { ...cat, count: (existing?.count ?? 0) + 1 });
    }
  }
  const allCategories = [...categoryMap.values()].sort((a, b) => a.name.localeCompare(b.name));

  // Build tag map
  const tagMap = new Map<string, { name: string; slug: string }>();
  for (const entry of works) {
    for (const tag of entry.data.tags ?? []) {
      if (!tagMap.has(tag.slug)) tagMap.set(tag.slug, tag);
    }
  }

  return [...tagMap.values()].map((tag) => ({
    params: { slug: tag.slug },
    props: {
      tagName: tag.name,
      allCategories,
      totalCount: works.length,
      works: works.filter((e) => e.data.tags?.some((t) => t.slug === tag.slug)),
    },
  }));
}

interface Props {
  tagName: string;
  allCategories: { name: string; slug: string; count: number }[];
  totalCount: number;
  works: CollectionEntry<'work'>[];
}

const { tagName, allCategories, totalCount, works } = Astro.props;
const { slug } = Astro.params;
---

<Layout
  title={tagName}
  description={`Works tagged "${tagName}" by Giorgos Chronopoulos.`}
>
  <WorkGrid
    works={works}
    allCategories={allCategories}
    totalCount={totalCount}
    activeTag={slug}
    filterLabel={tagName}
  />
</Layout>
