---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import ArticleList from '../../components/ArticleList.astro';

export const prerender = true;

const allNews = await getCollection('article').catch(() => []);

const news = [...allNews]
  .filter((entry) => !!entry.data.alias)
  .sort((a, b) => {
    const aDate = Date.parse(a.data.created ?? '');
    const bDate = Date.parse(b.data.created ?? '');
    if (!Number.isNaN(aDate) && !Number.isNaN(bDate)) return bDate - aDate;
    return a.data.title.localeCompare(b.data.title);
  });
---

<Layout title="News" description="Latest news and updates by Giorgos Chronopoulos.">
    <h1 class="text-4xl font-semibold mb-8">News & Events</h1>
  <section class="max-w-5xl mx-auto">
    {news.length === 0 && (
      <p class="text-neutral-600">No news published yet.</p>
    )}

    {news.length > 0 && <ArticleList items={news} />}
  </section>
</Layout>
