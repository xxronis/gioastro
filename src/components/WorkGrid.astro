---
import { Image } from 'astro:assets';
import { cfImg } from '../lib/jsonapi-images';
import type { CollectionEntry } from 'astro:content';

interface Category {
  name: string;
  slug: string;
  count: number;
}

interface Props {
  works: CollectionEntry<'work'>[];
  allCategories: Category[];
  totalCount: number;
  activeCategory?: string;
  activeTag?: string;
  filterLabel?: string;
  title?: boolean;
}

const { works, allCategories, totalCount, activeCategory, activeTag, filterLabel, title = true } = Astro.props;
const isAll = !activeCategory && !activeTag;
---

<!-- <div class="container mx-auto w-[90%] lg:w-[80%] py-8"> -->
{title && (
  <div class="sticky top-[var(--header-h,0px)] z-10 bg-white/90 backdrop-blur-sm flex items-center justify-between gap-4 py-4 mb-4 flex-wrap" transition:animate="none">
    
      <h1 class="text-4xl font-semibold">
        Work
        {filterLabel && <span class="text-lg font-normal text-neutral-500 ml-2">— {filterLabel}</span>}
      </h1>
    
    {allCategories.length > 0 && (
      <div class="flex flex-wrap gap-x-6 gap-y-1">
        <a
          href="/work"
          class:list={[
            "group inline-flex items-center gap-1.5 pb-0.5 border-b-2 text-sm font-medium transition-colors",
            isAll ? "border-neutral-900" : "border-transparent hover:border-neutral-900 hover:text-neutral-900",
          ]}
        >
          All
          <span class="text-xs text-neutral-400">{totalCount}</span>
        </a>
        {allCategories.map((cat) => (
          <a
            href={`/work/category/${cat.slug}`}
            class:list={[
              "group inline-flex items-center gap-1.5 pb-0.5 border-b-2 text-sm font-medium transition-colors",
              cat.slug === activeCategory
                ? "border-neutral-900 text-neutral-900"
                : "border-transparent hover:border-neutral-900 hover:text-neutral-900",
            ]}
          >
            {cat.name}
            <span class="text-xs text-neutral-400">{cat.count}</span>
          </a>
        ))}
      </div>
    )}
  </div>
)}
<ul class="columns-1 sm:columns-2 lg:columns-3 [column-gap:1.5rem]">
  {works.map((entry, index) => {
    const img = entry.data.images[0];
    const statuses = entry.data.statuses ?? [];
    return (
      <li class="mb-6 break-inside-avoid">
        <a class="group block w-full overflow-hidden shadow bg-white relative" href={entry.data.alias}>
          {img && (
            <Image
              src={cfImg(img.src, { width: 600, quality: 85 })}
              srcset={`${cfImg(img.src, { width: 600, quality: 85 })} 600w, ${cfImg(img.src, { width: 1200, quality: 85 })} 1200w`}
              sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
              loading={index > 9 ? "lazy" : "eager"}
              decoding="async"
              alt={img.alt ?? ""}
              width={600}
              height={600}
              class="block w-full h-auto"
            />
          )}
          <div class="pointer-events-none absolute inset-x-0 bottom-0 bg-neutral-900/60 px-4 py-3
                      opacity-100 md:opacity-0 md:group-hover:opacity-100 transition-opacity">
            <div class="text-white leading-snug">{entry.data.title}</div>
            {statuses.length > 0 && (
              <div class="flex flex-wrap gap-1 mt-1">
                {statuses.map((s) => (
                  <span class="text-xs bg-white/20 text-white px-1.5 py-0.5 rounded">{s}</span>
                ))}
              </div>
            )}
          </div>
        </a>
      </li>
    );
  })}
</ul>
<!-- </div> -->
