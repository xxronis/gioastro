---
import { cfImg } from '../lib/jsonapi-images';
import type { CollectionEntry } from 'astro:content';

interface Props {
  items: CollectionEntry<'article'>[];
}

const { items } = Astro.props;

function toNewsSlug(alias: string, id: string) {
  const parts = alias.split('/').filter(Boolean);
  return parts[parts.length - 1] ?? id;
}
---

<ul class="space-y-8 max-w-3xl mx-auto">
  {items.map((entry) => {
    const img = entry.data.images?.[0];
    const slug = toNewsSlug(entry.data.alias, entry.id);
    const href = `/news/${slug}`;

    return (
      <li>
        <article class="flex flex-col gap-4 pb-8 md:flex-row md:gap-6 md:items-start md:border-b md:border-neutral-200">
          <a href={href} class="h-[180px] shrink-0 flex items-center justify-center md:w-[320px]">
            {img ? (
              <img
                src={cfImg(img.src, { width: 640, height: 600, quality: 85 })}
                alt={img.alt ?? ''}
                width="640"
                height="600"
                loading="lazy"
                decoding="async"
                class="h-full w-auto max-w-[320px] object-cover"
              />
            ) : (
              <div class="h-full flex items-center justify-center text-sm text-neutral-400">No image</div>
            )}
          </a>

          <div class="min-w-0 flex flex-col flex-1 pt-1 md:min-h-[180px]">
            <h2 class="text-2xl font-semibold leading-tight text-center md:text-left">
              <a href={href} class="hover:underline underline-offset-4">{entry.data.title}</a>
            </h2>
            <a href={href} class="hidden md:inline-block md:mt-auto md:self-end text-sm font-medium tracking-wide uppercase hover:underline underline-offset-4">
              Read more
            </a>
          </div>
        </article>
      </li>
    );
  })}
</ul>
